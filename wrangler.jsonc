{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "mercuryproject",
  "main": "_worker.js",
  "compatibility_date": "2026-07-24",
  "compatibility_flags": ["nodejs_compat"],
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": ".",
    "binding": "ASSETS"
  }
}
